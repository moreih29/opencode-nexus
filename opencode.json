{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "AGENTS.md"
  ],
  "default_agent": "nexus",
  "agent": {
    "build": {
      "disable": true
    },
    "plan": {
      "disable": true
    },
    "nexus": {
      "mode": "primary",
      "model": "openai/gpt-5.4"
    },
    "architect": {
      "mode": "subagent",
      "model": "openai/gpt-5.4"
    },
    "designer": {
      "mode": "subagent",
      "model": "openai/gpt-5.4"
    },
    "postdoc": {
      "mode": "subagent",
      "model": "openai/gpt-5.4"
    },
    "strategist": {
      "mode": "subagent",
      "model": "openai/gpt-5.4"
    },
    "engineer": {
      "mode": "subagent",
      "model": "opencode-go/minimax-m2.7"
    },
    "researcher": {
      "mode": "subagent",
      "model": "opencode-go/minimax-m2.7"
    },
    "writer": {
      "mode": "subagent",
      "model": "opencode-go/minimax-m2.7"
    },
    "reviewer": {
      "mode": "subagent",
      "model": "opencode-go/minimax-m2.7"
    },
    "tester": {
      "mode": "subagent",
      "model": "opencode-go/minimax-m2.7"
    }
  },
  "permission": {
    "*": "allow"
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    }
  },
  "plugin": []
}
