{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "opencode-nexus@0.13.0"
  ],
  "mcp": {
    "nx": {
      "type": "local",
      "command": [
        "nexus-mcp"
      ]
    }
  },
  "default_agent": "lead",
  "agent": {
    "architect": {
      "model": "openai/gpt-5.4"
    },
    "designer": {
      "model": "openai/gpt-5.4"
    },
    "postdoc": {
      "model": "openai/gpt-5.4"
    },
    "strategist": {
      "model": "openai/gpt-5.4"
    },
    "lead": {
      "model": "anthropic/claude-opus-4-7"
    },
    "engineer": {
      "model": "openai/gpt-5.3-codex"
    },
    "researcher": {
      "model": "opencode-go/kimi-k2.6"
    },
    "writer": {
      "model": "opencode-go/kimi-k2.6"
    },
    "reviewer": {
      "model": "opencode-go/kimi-k2.6"
    },
    "tester": {
      "model": "opencode-go/minimax-m2.7"
    },
    "build": {
      "disable": true
    },
    "plan": {
      "disable": true
    }
  }
}
