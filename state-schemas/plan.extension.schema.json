{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/moreih29/opencode-nexus/blob/main/state-schemas/plan.extension.schema.json",
  "title": "PlanExtension",
  "description": "Sidecar extension for plan.json — opencode-nexus platform-specific panel and handoff state.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "canonical_file", "platform", "handoff", "panel"],
  "properties": {
    "schema_version": {
      "const": 1,
      "description": "Schema version sentinel. Always 1."
    },
    "canonical_file": {
      "const": "plan.json",
      "description": "The canonical base file this sidecar extends."
    },
    "platform": {
      "const": "opencode",
      "description": "Platform identifier."
    },
    "handoff": {
      "type": "object",
      "additionalProperties": false,
      "required": ["policy", "canonical_ready", "updated_at"],
      "properties": {
        "policy": {
          "const": "canonical-first",
          "description": "Handoff read/write policy."
        },
        "canonical_ready": {
          "type": "boolean",
          "description": "Whether the canonical plan.json is ready for handoff."
        },
        "updated_at": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp of the last handoff state update."
        }
      }
    },
    "panel": {
      "type": "object",
      "additionalProperties": false,
      "required": ["strategy", "participants"],
      "properties": {
        "strategy": {
          "const": "how-fixed-panel",
          "description": "Panel composition strategy."
        },
        "participants": {
          "type": "array",
          "description": "Active panel participants and their session continuity handles.",
          "items": {
            "$ref": "#/$defs/PanelParticipant"
          }
        }
      }
    }
  },
  "$defs": {
    "PanelParticipant": {
      "type": "object",
      "additionalProperties": false,
      "required": ["role", "updated_at"],
      "properties": {
        "role": {
          "type": "string",
          "description": "Agent role identifier (e.g. architect, designer)."
        },
        "session_id": {
          "type": ["string", "null"],
          "description": "OpenCode session ID for resume continuity."
        },
        "task_id": {
          "type": ["string", "null"],
          "description": "OpenCode task ID for resume continuity."
        },
        "last_summary": {
          "type": ["string", "null"],
          "description": "Last summary message recorded by this participant."
        },
        "updated_at": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp of the last participant update."
        }
      }
    }
  }
}
