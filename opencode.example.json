{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["opencode-nexus"],
  "instructions": ["AGENTS.md"],
  "default_agent": "nexus",
  "agent": {
    "build": {
      "disable": true
    },
    "plan": {
      "disable": true
    },
    "nexus": {
      "description": "Nexus-aware orchestration lead for meet, run, delegation, and verification workflows",
      "mode": "primary",
      "color": "accent"
    },
    "architect": {
      "description": "Technical design and architecture review",
      "mode": "subagent",
      "model": "opencode-go/minimax-m2.7",
      "tools": {
        "edit": false,
        "write": false,
        "patch": false,
        "multiedit": false,
        "nx_task_add": false,
        "nx_task_update": false
      }
    },
    "engineer": {
      "description": "Code implementation and debugging",
      "mode": "subagent",
      "model": "opencode-go/minimax-m2.7",
      "tools": {
        "nx_task_add": false
      }
    }
  },
  "permission": {
    "*": "ask",
    "edit": "ask",
    "bash": {
      "*": "ask",
      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow"
    },
    "task": {
      "*": "allow"
    }
  }
}
