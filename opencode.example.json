{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["opencode-nexus"],
  "default_agent": "build",
  "agent": {
    "architect": {
      "description": "Technical design and architecture review",
      "mode": "subagent",
      "model": "anthropic/claude-sonnet-4-5",
      "tools": {
        "edit": false,
        "write": false,
        "patch": false,
        "multiedit": false,
        "nx_task_add": false,
        "nx_task_update": false
      }
    },
    "engineer": {
      "description": "Code implementation and debugging",
      "mode": "subagent",
      "model": "anthropic/claude-sonnet-4-5",
      "tools": {
        "nx_task_add": false
      }
    },
    "qa": {
      "description": "Verification and test-focused review",
      "mode": "subagent",
      "model": "anthropic/claude-sonnet-4-5",
      "tools": {
        "nx_task_add": false
      }
    }
  },
  "permission": {
    "*": "ask",
    "edit": "ask",
    "bash": {
      "*": "ask",
      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow"
    },
    "task": {
      "*": "allow"
    }
  }
}
