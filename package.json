{
  "name": "opencode-nexus",
  "version": "0.10.0",
  "private": false,
  "type": "module",
  "description": "OpenCode plugin wrapper delivering nexus-core shared runtime substrate",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/moreih29/opencode-nexus.git"
  },
  "homepage": "https://github.com/moreih29/opencode-nexus#readme",
  "bugs": {
    "url": "https://github.com/moreih29/opencode-nexus/issues"
  },
  "keywords": [
    "opencode",
    "plugin",
    "nexus",
    "nexus-core",
    "agents",
    "orchestration"
  ],
  "packageManager": "bun@1.3.9",
  "engines": {
    "node": ">=22"
  },
  "main": "./src/plugin.ts",
  "exports": {
    ".": "./src/plugin.ts"
  },
  "files": [
    "src",
    ".opencode/skills/deploy"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "sync": "bunx @moreih29/nexus-core sync --harness=opencode --target=./",
    "sync:dry": "bunx @moreih29/nexus-core sync --harness=opencode --target=./ --dry-run",
    "sync:strict": "bunx @moreih29/nexus-core sync --harness=opencode --target=./ --strict",
    "validate": "bunx @moreih29/nexus-core validate",
    "build": "bun run sync && tsc --noEmit",
    "check": "bun run sync:dry && tsc --noEmit",
    "test:e2e": "bun scripts/e2e-nexus-integration.mjs",
    "prepack": "bun run sync:strict"
  },
  "dependencies": {
    "@moreih29/nexus-core": "^0.15.1",
    "@opencode-ai/plugin": "1.4.7"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "typescript": "^5.6.3"
  }
}
