{
  "name": "opencode-nexus",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Nexus orchestration plugin for OpenCode",
  "packageManager": "bun@1.3.9",
  "main": "dist/index.js",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "test:e2e": "bun run build && bun scripts/e2e-smoke.mjs && bun scripts/e2e-guardrails.mjs"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "latest",
    "@types/node": "^22.10.1",
    "typescript": "^5.6.3"
  }
}
