{
  "name": "opencode-nexus",
  "version": "0.13.2",
  "private": false,
  "type": "module",
  "description": "OpenCode plugin wrapper for @moreih29/nexus-core",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/moreih29/opencode-nexus.git"
  },
  "homepage": "https://github.com/moreih29/opencode-nexus#readme",
  "bugs": {
    "url": "https://github.com/moreih29/opencode-nexus/issues"
  },
  "keywords": [
    "opencode",
    "plugin",
    "nexus",
    "nexus-core",
    "agents",
    "orchestration"
  ],
  "packageManager": "bun@1.3.9",
  "engines": {
    "node": ">=22"
  },
  "main": "./src/plugin.ts",
  "exports": {
    ".": "./src/plugin.ts"
  },
  "bin": {
    "opencode-nexus": "./bin/opencode-nexus.mjs"
  },
  "files": [
    "src",
    "bin",
    "lib",
    "skills"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "sync": "./node_modules/.bin/nexus-sync --harness=opencode --target=./",
    "sync:dry": "./node_modules/.bin/nexus-sync --harness=opencode --target=./ --dry-run",
    "build": "bun run sync && tsc --noEmit",
    "check": "bun run sync:dry && tsc --noEmit",
    "test:e2e": "bun run sync && bun scripts/e2e-nexus-integration.mjs",
    "bootstrap": "bun run sync && node ./bin/opencode-nexus.mjs install --scope=project --skip-models --force",
    "prepack": "bun run build"
  },
  "dependencies": {
    "@moreih29/nexus-core": "0.19.1",
    "@opencode-ai/plugin": "1.4.9",
    "ink": "^7.0.1",
    "react": "^19.2.5"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "typescript": "^5.6.3"
  }
}
